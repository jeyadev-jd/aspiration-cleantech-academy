# Express Server Port
PORT=5000

# React Frontend Origin (Whitelist)
FRONTEND_URL=http://localhost:5173

# MongoDB Atlas Connection String (Never commit the real password to git)
# Example: mongodb+srv://<db_username>:<db_password>@cluster0.abcde.mongodb.net/?retryWrites=true&w=majority&appName=Cluster0
MONGO_URI=

# Secret used to sign admin JWTs - use a long random string in production
JWT_SECRET=

# Cloudinary (image uploads for course images)
CLOUD_NAME=
CLOUD_KEY=
CLOUD_SECRET=

# Cloudflare Turnstile secret key (optional - admin login captcha, from Cloudflare dashboard > Turnstile)
TURNSTILE_SECRET_KEY=
